            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>verifyFailAssign</name>
        <label>verifyFailAssign</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isVerified</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Verify_OTP.isVerified</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>output_Message_Flow2</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>failVerificationMsg</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>verified_or_not</name>
        <label>verified or not</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>verifyFailAssign</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Verified</defaultConnectorLabel>
        <rules>
            <name>Verified</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Verify_OTP.isVerified</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_contact</targetReference>
            </connector>
            <label>Verified</label>
        </rules>
    </decisions>
    <description>Used to verify the OTP entered by the user</description>
    <environments>Default</environments>
