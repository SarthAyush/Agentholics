        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isVerified</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Verify_OTP.isVerified</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>output_Message_Flow2</assignToReference>
            <operator>Assign</operator>
            <value>
