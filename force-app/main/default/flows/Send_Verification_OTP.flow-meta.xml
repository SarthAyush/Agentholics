        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>verification_message_initial</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>errormessage</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
